{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://embeddedknowledge.io/schemas/lesson-index.schema.json",
  "title": "EmbeddedKnowledge course lesson production index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "generatedAt", "course", "repository", "stateDefinitions", "summary", "domains", "outcomes", "lessons"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "minLength": 10 },
    "course": { "enum": ["premed", "psychiatry"] },
    "repository": { "type": "string", "format": "uri" },
    "stateDefinitions": {
      "type": "object", "additionalProperties": false,
      "required": ["empty", "inReview", "published"],
      "properties": { "empty": { "type": "string" }, "inReview": { "type": "string" }, "published": { "type": "string" } }
    },
    "summary": {
      "type": "object", "additionalProperties": false,
      "required": ["outcomes", "mergedLessons", "publishedLessons", "outcomesCoveredByPublishedLessons"],
      "properties": {
        "outcomes": { "type": "integer", "minimum": 0 },
        "mergedLessons": { "type": "integer", "minimum": 0 },
        "publishedLessons": { "type": "integer", "minimum": 0 },
        "outcomesCoveredByPublishedLessons": { "type": "integer", "minimum": 0 }
      }
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "title", "color", "order"],
        "properties": { "id": { "type": "string", "pattern": "^domain-" }, "title": { "type": "string" }, "color": { "type": "string" }, "order": { "type": "number" } }
      }
    },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "code", "title", "outcome", "summary", "domainId", "domainTitle", "moduleId", "moduleTitle", "requirement", "level", "estimatedHours", "prerequisites", "crossLinks", "lessonIds", "publishedLessonIds"],
        "properties": {
          "id": { "type": "string", "pattern": "^topic-" },
          "code": { "type": "string" },
          "title": { "type": "string" },
          "outcome": { "type": "string" },
          "summary": { "type": "string" },
          "domainId": { "type": "string", "pattern": "^domain-" },
          "domainTitle": { "type": "string" },
          "moduleId": { "type": "string", "pattern": "^module-" },
          "moduleTitle": { "type": ["string", "null"] },
          "requirement": { "type": "string" },
          "level": { "type": "string" },
          "estimatedHours": { "type": "number", "minimum": 0 },
          "prerequisites": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^topic-" } },
          "crossLinks": { "type": "array", "uniqueItems": true, "items": { "type": "string" } },
          "lessonIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^(?:PREM|PSY)-" } },
          "publishedLessonIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^(?:PREM|PSY)-" } }
        }
      }
    },
    "lessons": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "version", "title", "status", "riskTier", "estimatedMinutes", "outcomeIds", "prerequisiteIds", "license", "sourceConfidence", "dataUrl", "readerUrl"],
        "properties": {
          "id": { "type": "string", "pattern": "^(?:PREM|PSY)-" },
          "version": { "type": "string" },
          "title": { "type": "string" },
          "status": { "enum": ["draft", "in-review", "adjudicated", "published"] },
          "riskTier": { "enum": ["minor-correction", "standard", "high-impact"] },
          "estimatedMinutes": { "type": "integer", "minimum": 0 },
          "outcomeIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^topic-" } },
          "prerequisiteIds": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^topic-" } },
          "license": { "const": "CC-BY-4.0" },
          "sourceConfidence": { "type": "string" },
          "dataUrl": { "type": "string", "pattern": "^/data/lessons/(?:PREM|PSY)-[A-Z]{3}-[0-9]{3}\\.json$" },
          "readerUrl": { "type": "string", "pattern": "^/(?:premed|psychiatry)/lessons/read/\\?lesson=(?:PREM|PSY)-[A-Z]{3}-[0-9]{3}$" }
        }
      }
    }
  }
}
