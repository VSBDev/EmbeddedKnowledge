{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://embeddedknowledge.io/schemas/diagram.schema.json",
  "title": "EmbeddedKnowledge safe declarative diagram v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "format", "id", "type", "direction", "alt", "longDescription", "nodes", "edges"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "format": { "const": "embeddedknowledge-diagram-v1" },
    "id": { "type": "string", "pattern": "^diagram-[a-z0-9-]+$" },
    "type": { "enum": ["flow", "concept-map", "process", "cycle", "timeline"] },
    "direction": { "enum": ["left-to-right", "right-to-left", "top-to-bottom", "bottom-to-top", "radial"] },
    "alt": { "type": "string", "minLength": 8, "maxLength": 500 },
    "longDescription": { "type": "string", "minLength": 20, "maxLength": 5000 },
    "nodes": {
      "type": "array", "minItems": 1, "maxItems": 100,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "label", "shape"],
        "properties": {
          "id": { "type": "string", "pattern": "^node-[a-z0-9-]+$" },
          "label": { "type": "string", "minLength": 1, "maxLength": 300 },
          "shape": { "enum": ["box", "rounded-box", "circle", "ellipse", "diamond", "pill"] },
          "group": { "type": ["string", "null"], "pattern": "^[a-z0-9-]+$" }
        }
      }
    },
    "edges": {
      "type": "array", "maxItems": 200,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "from", "to", "kind", "label"],
        "properties": {
          "id": { "type": "string", "pattern": "^edge-[a-z0-9-]+$" },
          "from": { "type": "string", "pattern": "^node-[a-z0-9-]+$" },
          "to": { "type": "string", "pattern": "^node-[a-z0-9-]+$" },
          "kind": { "enum": ["directed", "undirected", "inhibits", "activates", "transforms", "balances"] },
          "label": { "type": ["string", "null"], "maxLength": 300 }
        }
      }
    }
  }
}
