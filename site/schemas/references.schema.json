{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://embeddedknowledge.io/schemas/references.schema.json",
  "title": "EmbeddedKnowledge lesson source and reuse registry v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "format", "lessonId", "lessonVersion", "sources"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "format": { "const": "embeddedknowledge-references-v2" },
    "lessonId": { "type": "string", "pattern": "^PREM-[A-Z]{3}-[0-9]{3}$" },
    "lessonVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "sources": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "type", "title", "creators", "publisher", "issued", "url", "accessed", "version", "locator", "license", "archivedUrl", "uses", "agentAccess"],
        "properties": {
          "id": { "type": "string", "pattern": "^source-[a-z0-9-]+$" },
          "type": { "enum": ["primary-research", "systematic-review", "review", "textbook", "official-standard", "guideline", "dataset", "reference-work", "oer", "other"] },
          "title": { "type": "string", "minLength": 3, "maxLength": 500 },
          "creators": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "maxLength": 200 } },
          "publisher": { "type": ["string", "null"], "maxLength": 200 },
          "issued": { "type": ["string", "null"], "pattern": "^[0-9]{4}(?:-[0-9]{2}(?:-[0-9]{2})?)?$" },
          "url": { "type": "string", "format": "uri", "pattern": "^https://" },
          "accessed": { "type": "string", "format": "date" },
          "version": { "type": ["string", "null"], "maxLength": 200 },
          "locator": { "type": ["string", "null"], "maxLength": 500 },
          "license": { "type": ["string", "null"], "maxLength": 200 },
          "archivedUrl": { "type": ["string", "null"], "format": "uri", "pattern": "^https://" },
          "uses": {
            "type": "array", "minItems": 1,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["usageType", "rightsBasis", "rightsBasisEvidence"],
              "properties": {
                "usageType": {
                  "enum": ["factual-reference", "verbatim-quotation", "adapted-expression", "redistributed-media", "dataset-extraction"]
                },
                "rightsBasis": {
                  "enum": ["facts-only-original-expression", "cc-by-4.0", "cc0-1.0", "public-domain", "written-permission"]
                },
                "rightsBasisEvidence": { "type": "string", "minLength": 12, "maxLength": 2000 }
              },
              "allOf": [
                {
                  "if": { "properties": { "usageType": { "const": "factual-reference" } } },
                  "then": { "properties": { "rightsBasis": { "const": "facts-only-original-expression" } } }
                },
                {
                  "if": { "properties": { "rightsBasis": { "const": "facts-only-original-expression" } } },
                  "then": { "properties": { "usageType": { "const": "factual-reference" } } }
                }
              ]
            }
          },
          "agentAccess": {
            "type": "object", "additionalProperties": false,
            "required": ["status", "termsUrl", "checked", "notes"],
            "properties": {
              "status": { "enum": ["checked-no-agent-restriction-found", "human-only"] },
              "termsUrl": { "type": ["string", "null"], "format": "uri", "pattern": "^https://" },
              "checked": { "type": "string", "format": "date" },
              "notes": { "type": "string", "minLength": 8, "maxLength": 2000 }
            }
          }
        }
      }
    }
  }
}
