{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://embeddedknowledge.io/schemas/glossary.schema.json",
  "title": "EmbeddedKnowledge lesson glossary v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "format", "lessonId", "lessonVersion", "terms"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "format": { "const": "embeddedknowledge-glossary-v1" },
    "lessonId": { "type": "string", "pattern": "^PREM-[A-Z]{3}-[0-9]{3}$" },
    "lessonVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "terms": {
      "type": "array",
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "term", "definition", "aliases", "sceneIds"],
        "properties": {
          "id": { "type": "string", "pattern": "^term-[a-z0-9-]+$" },
          "term": { "type": "string", "minLength": 1, "maxLength": 160 },
          "definition": { "type": "string", "minLength": 5, "maxLength": 1000 },
          "aliases": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1, "maxLength": 160 } },
          "sceneIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^scene-[a-z0-9-]+$" } }
        }
      }
    }
  }
}
