  "objectives": [
    {
      "id": "objective-distinguish-evidence-contributions",
      "statement": "Distinguish what molecular, organismal, population, and intervention evidence can contribute to a causal question and state a material limit of each line.",
      "outcomeIds": [
        "topic-scientific-inquiry-mechanism-evidence"
      ]
    },
    {
      "id": "objective-weigh-convergence",
      "statement": "Weigh evidence lines for reliability, relevance, consistency, and independence rather than treating studies as equal votes.",
      "outcomeIds": [
        "topic-scientific-inquiry-mechanism-evidence"
      ]
    },
    {
      "id": "objective-write-calibrated-claim",
      "statement": "Integrate a multiscale evidence bundle into a claim that names its strength, causal scope, pivotal support, and remaining uncertainty.",
      "outcomeIds": [
        "topic-scientific-inquiry-mechanism-evidence"
      ]
    },
    {
      "id": "objective-resolve-conflict",
      "statement": "Revise an integrated claim when evidence conflicts and propose a study that discriminates between plausible explanations for the conflict.",
      "outcomeIds": [
        "topic-scientific-inquiry-mechanism-evidence"
      ]
    }
  ],
