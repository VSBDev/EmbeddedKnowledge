{"id":"term-proportion","term":"proportion","definition":"An equation asserting that two ratios are equal.","aliases":["equivalent-ratio equation"],"sceneIds":["scene-concept","scene-worked-example","scene-practice","scene-synthesis"]},
{"id":"term-percentage","term":"percentage","definition":"A ratio expressed per hundred relative to a named whole or reference quantity.","aliases":["percent"],"sceneIds":["scene-orientation","scene-concept","scene-misconception","scene-practice","scene-transfer","scene-synthesis"]},
{"id":"term-percent-change","term":"percent change","definition":"The change divided by the starting value, expressed as a percentage and labeled as an increase or decrease.","aliases":["relative percentage change"],"sceneIds":["scene-orientation","scene-concept","scene-misconception","scene-practice","scene-transfer","scene-synthesis"]},
