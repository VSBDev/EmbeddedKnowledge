  "objectives": [
    {
      "id": "objective-detect-six-biases",
      "statement": "Detect selection, information, observer, attrition, publication, and survivorship bias from the inclusion, measurement, retention, survival, or dissemination mechanism described in a study.",
      "outcomeIds": [
        "topic-scientific-inquiry-bias"
      ]
    },
    {
      "id": "objective-justify-threat",
      "statement": "Explain which target estimate or conclusion a suspected bias threatens and state its likely direction only when the available inclusion, measurement, missingness, or reporting evidence supports that direction.",
      "outcomeIds": [
        "topic-scientific-inquiry-bias"
      ]
    },
    {
      "id": "objective-audit-new-study",
      "statement": "Audit a new evidence path and propose a stage-matched record, comparison, masking procedure, denominator repair, or reporting check for each material bias concern.",
      "outcomeIds": [
        "topic-scientific-inquiry-bias"
      ]
    }
  ],
