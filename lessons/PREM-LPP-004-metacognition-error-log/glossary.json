  "terms": [
    {
      "id": "term-metacognitive-monitoring",
      "term": "metacognitive monitoring",
      "definition": "In this lesson, collecting and interpreting evidence about current knowledge or task performance, including the conditions, response, score, and confidence judgment.",
      "aliases": [
        "monitoring"
      ],
      "sceneIds": [
        "scene-orientation",
        "scene-concept",
        "scene-worked-example",
        "scene-synthesis"
      ]
    },
    {
      "id": "term-metacognitive-control",
      "term": "metacognitive control",
      "definition": "In this lesson, selecting or changing a learning action in response to a monitoring judgment and then collecting new evidence from the result.",
      "aliases": [
        "control",
        "regulation"
      ],
      "sceneIds": [
        "scene-orientation",
        "scene-concept",
        "scene-worked-example",
        "scene-synthesis"
      ]
    },
    {
      "id": "term-confidence-judgment",
      "term": "confidence judgment",
      "definition": "In this lesson, a task-bounded prediction made after committing a response but before feedback of the percentage of points the response will earn on a declared rubric.",
      "aliases": [
        "confidence rating"
      ],
      "sceneIds": [
        "scene-orientation",
        "scene-concept",
        "scene-calibration",
        "scene-worked-example",
        "scene-practice"
      ]
    },
    {
      "id": "term-calibration",
      "term": "calibration",
      "definition": "The relation between a predicted rubric percentage and the percentage actually earned for a defined task using that same scoring rule.",
      "aliases": [
        "confidence calibration"
      ],
      "sceneIds": [
        "scene-concept",
        "scene-calibration",
        "scene-worked-example",
        "scene-retrieval",
        "scene-practice",
        "scene-synthesis",
        "scene-assessment"
      ]
    },
    {
      "id": "term-signed-calibration-gap",
      "term": "signed calibration gap",
      "definition": "Predicted rubric percentage minus observed rubric percentage for one matched task; a positive value means the prediction exceeded performance and a negative value means the prediction was lower.",
      "aliases": [
        "calibration gap"
      ],
      "sceneIds": [
        "scene-calibration",
        "scene-worked-example",
        "scene-retrieval",
        "scene-practice",
        "scene-synthesis",
        "scene-assessment"
      ]
    },
    {
      "id": "term-first-broken-link",
      "term": "first broken link",
      "definition": "The earliest operation in the lesson's interpret–retrieve–select–execute–verify chain whose required evidence is absent or contradicted in the current task record.",
      "aliases": [
        "earliest unsupported operation"
      ],
      "sceneIds": [
        "scene-concept",
        "scene-calibration",
        "scene-worked-example",
        "scene-misconception",
        "scene-retrieval",
        "scene-practice",
        "scene-transfer",
        "scene-synthesis",
        "scene-assessment"
      ]
    },
    {
      "id": "term-error-category",
      "term": "error category",
      "definition": "A provisional action-oriented label for the first unsupported operation in a bounded task record, not an exhaustive cause or a label for the learner.",
      "aliases": [
        "error classification"
      ],
      "sceneIds": [
        "scene-concept",
        "scene-calibration",
        "scene-worked-example",
        "scene-misconception",
        "scene-practice",
        "scene-transfer",
        "scene-synthesis",
        "scene-assessment"
      ]
    },
    {
      "id": "term-error-log",
      "term": "error log",
      "definition": "A structured record linking task conditions and attempt evidence to a provisional error hypothesis, confidence calibration, a targeted learning action, and a fresh probe.",
      "aliases": [
        "learning error log"
      ],
      "sceneIds": [
        "scene-orientation",
        "scene-concept",
        "scene-worked-example",
        "scene-practice",
        "scene-transfer",
        "scene-synthesis",
        "scene-assessment"
      ]
    },
    {
      "id": "term-targeted-action",
      "term": "targeted learning action",
      "definition": "A study activity selected because it directly exercises the operation currently proposed as the first broken link.",
      "aliases": [
        "matching action"
      ],
      "sceneIds": [
        "scene-concept",
        "scene-worked-example",
        "scene-misconception",
        "scene-practice",
        "scene-transfer",
        "scene-synthesis",
        "scene-assessment"
      ]
    },
    {
      "id": "term-fresh-probe",
      "term": "fresh probe",
      "definition": "A new attempt, usually varied or delayed, designed to reveal whether a targeted repair changed the relevant operation and whether the earlier diagnosis should be retained or revised.",
      "aliases": [
        "retest",
        "discriminating probe"
      ],
