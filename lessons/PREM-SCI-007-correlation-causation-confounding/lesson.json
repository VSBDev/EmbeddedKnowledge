  "objectives": [
    {
      "id": "objective-distinguish-inference-targets",
      "statement": "Classify a study conclusion as association, mechanism, bounded causal attribution, or unsupported from the described evidence.",
      "outcomeIds": [
        "topic-scientific-inquiry-correlation-causation"
      ]
    },
    {
      "id": "objective-map-rival-paths",
      "statement": "Use time order and causal arrow maps to distinguish confounders, reverse causation, mediators, and colliders and to judge whether adjustment serves the stated causal question.",
      "outcomeIds": [
        "topic-scientific-inquiry-correlation-causation"
      ]
    },
    {
      "id": "objective-calibrate-causal-attribution",
      "statement": "Justify the strongest warranted claim from a randomized, observational, or natural-experiment comparison while stating its identifying assumptions and a material scope boundary.",
      "outcomeIds": [
        "topic-scientific-inquiry-correlation-causation"
      ]
    }
  ],
