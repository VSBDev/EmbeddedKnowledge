{
  "schemaVersion": 1,
  "format": "embeddedknowledge-glossary-v1",
  "lessonId": "PREM-SCI-003",
  "lessonVersion": "0.1.1",
  "terms": [
    {
      "id": "term-variable",
      "term": "variable",
      "definition": "A feature or quantity that can take different values or conditions in a comparison.",
      "aliases": [
        "factor"
      ],
      "sceneIds": [
        "scene-zero-two-meanings",
        "scene-worked-run",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-independent-variable",
      "term": "independent variable",
      "definition": "In the experiments used in this lesson, the factor deliberately changed between the main comparison conditions.",
      "aliases": [
        "manipulated variable",
        "experimental factor"
      ],
      "sceneIds": [
        "scene-zero-two-meanings",
        "scene-worked-run",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-dependent-variable",
      "term": "dependent variable",
      "definition": "The response recorded to examine whether it differs across levels of the independent variable.",
      "aliases": [
        "response variable",
        "outcome variable"
      ],
      "sceneIds": [
        "scene-zero-two-meanings",
        "scene-worked-run",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-controlled-variable",
      "term": "controlled variable",
      "definition": "Another relevant condition deliberately kept alike across the main comparison so it does not create a systematic rival difference.",
      "aliases": [
        "constant variable",
        "held-constant condition"
      ],
      "sceneIds": [
        "scene-zero-two-meanings",
        "scene-worked-run",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-confounder",
      "term": "confounder",
      "definition": "A factor that varies systematically with the independent variable and could also affect the dependent variable, creating a rival explanation for the observed difference.",
      "aliases": [
        "confounding variable"
      ],
      "sceneIds": [
        "scene-zero-two-meanings",
        "scene-worked-run",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-control-condition",
      "term": "control condition",
      "definition": "An extra comparison condition included to provide a baseline, known response, or another specific check on interpretation.",
      "aliases": [
        "control group"
      ],
      "sceneIds": [
        "scene-zero-two-meanings",
        "scene-worked-run",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-negative-control",
      "term": "negative control",
      "definition": "A control condition expected to show the baseline or no tested response, used to reveal background signal or a response where none is expected.",
      "aliases": [
        "negative-control condition",
        "baseline control"
      ],
      "sceneIds": [
        "scene-zero-two-meanings",
        "scene-worked-run",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-positive-control",
      "term": "positive control",
      "definition": "A control condition expected to produce a known response, used to check that the system can reveal the signal of interest.",
      "aliases": [
        "positive-control condition",
        "known-response control"
      ],
      "sceneIds": [
        "scene-zero-two-meanings",
        "scene-worked-run",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    }
  ]
}
