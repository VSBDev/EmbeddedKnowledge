{
  "schemaVersion": 1,
  "format": "embeddedknowledge-glossary-v1",
  "lessonId": "PREM-SCI-004",
  "lessonVersion": "0.1.0",
  "terms": [
    {
      "id": "term-exposure",
      "term": "exposure",
      "definition": "The intervention, condition, characteristic, or experience whose relationship with an outcome is being compared.",
      "aliases": [
        "exposure of interest"
      ],
      "sceneIds": [
        "scene-create-comparison",
        "scene-worked-choice",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-outcome",
      "term": "outcome",
      "definition": "The response, event, state, or measurement that a study records and compares.",
      "aliases": [
        "response"
      ],
      "sceneIds": [
        "scene-create-comparison",
        "scene-worked-choice",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-experiment",
      "term": "experiment",
      "definition": "A study in which researchers assign an intervention or exposure and compare outcomes under the assigned conditions.",
      "aliases": [
        "experimental study",
        "manipulated experiment"
      ],
      "sceneIds": [
        "scene-create-comparison",
        "scene-worked-choice",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-random-assignment",
      "term": "random assignment",
      "definition": "Allocation by a chance process that gives each eligible unit a known chance of receiving each study condition and makes groups comparable in expectation.",
      "aliases": [
        "random allocation"
      ],
      "sceneIds": [
        "scene-create-comparison",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-observational-study",
      "term": "observational study",
      "definition": "A study in which researchers do not assign the exposure being compared but record exposure and outcome differences that occur.",
      "aliases": [
        "observational design"
      ],
      "sceneIds": [
        "scene-create-comparison",
        "scene-worked-choice",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-cohort-study",
      "term": "cohort study",
      "definition": "An observational study that begins with a defined population or exposure groups and compares subsequent outcomes.",
      "aliases": [
        "cohort design"
      ],
      "sceneIds": [
        "scene-create-comparison",
        "scene-worked-choice",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-prospective-cohort",
      "term": "prospective cohort",
      "definition": "A cohort assembled before the outcomes of interest occur and followed forward as new outcomes are recorded.",
      "aliases": [
        "prospective cohort study"
      ],
      "sceneIds": [
        "scene-create-comparison",
        "scene-worked-choice",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-retrospective-cohort",
      "term": "retrospective cohort",
      "definition": "A cohort assembled from existing records that preserve an earlier exposure followed by a later outcome.",
      "aliases": [
        "historical cohort",
        "retrospective cohort study"
      ],
      "sceneIds": [
        "scene-create-comparison",
        "scene-worked-choice",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-case-control-study",
      "term": "case-control study",
      "definition": "An observational study that selects cases with an outcome and comparison controls without it from the population that produced the cases, then compares earlier exposure.",
      "aliases": [
        "case-control design"
      ],
      "sceneIds": [
        "scene-create-comparison",
        "scene-worked-choice",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-cross-sectional-study",
      "term": "cross-sectional study",
      "definition": "A study that measures exposure and outcome in a defined population at one time or over one brief window.",
      "aliases": [
        "cross-sectional design",
        "snapshot study"
      ],
      "sceneIds": [
        "scene-create-comparison",
        "scene-worked-choice",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-natural-experiment",
      "term": "natural experiment",
      "definition": "A study of exposure variation created by an external event, policy, rule, or implementation process rather than assigned by the research team; the assignment process must be examined before making experiment-like claims.",
      "aliases": [
        "natural experimental study"
      ],
      "sceneIds": [
        "scene-create-comparison",
        "scene-worked-choice",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    },
    {
      "id": "term-prevalence",
      "term": "prevalence",
      "definition": "The proportion of a defined population with a specified condition or characteristic at a stated time or over a stated period.",
      "aliases": [
        "prevalence proportion"
      ],
      "sceneIds": [
        "scene-create-comparison",
        "scene-practise-repair"
      ]
    },
    {
      "id": "term-causal-inference",
      "term": "causal inference",
      "definition": "A reasoned conclusion about whether changing an exposure would change an outcome, under stated assumptions and conditions.",
      "aliases": [
        "causal interpretation"
      ],
      "sceneIds": [
        "scene-create-comparison",
        "scene-worked-choice",
        "scene-practise-repair",
        "scene-transfer-synthesis"
      ]
    }
  ]
}
