  "terms": [
    {
      "id": "term-empirical-question",
      "term": "empirical question",
      "definition": "A question for which observations or measurements can bear on the answer.",
      "aliases": [
        "testable question",
        "empirically answerable question"
      ],
      "sceneIds": [
        "scene-explain-and-expect",
        "scene-worked-comparison",
        "scene-practise-and-repair",
        "scene-transfer"
      ]
    },
    {
      "id": "term-hypothesis",
      "term": "hypothesis",
      "definition": "A proposed explanation or relationship from which observable expectations can be derived.",
      "aliases": [
        "candidate explanation"
      ],
      "sceneIds": [
        "scene-explain-and-expect",
        "scene-worked-comparison",
        "scene-practise-and-repair",
        "scene-transfer"
      ]
    },
    {
      "id": "term-prediction",
      "term": "prediction",
      "definition": "An observable result expected if a stated hypothesis holds under stated conditions.",
      "aliases": [
        "expected observation",
        "expected outcome"
      ],
      "sceneIds": [
        "scene-explain-and-expect",
        "scene-worked-comparison",
        "scene-practise-and-repair",
        "scene-transfer"
      ]
    },
    {
      "id": "term-condition",
      "term": "condition",
      "definition": "A relevant feature of the case, setting, or comparison under which a prediction is expected to hold.",
      "aliases": [
        "stated condition"
      ],
      "sceneIds": [
        "scene-explain-and-expect",
        "scene-worked-comparison",
        "scene-practise-and-repair",
        "scene-transfer"
      ]
    },
    {
      "id": "term-competing-hypotheses",
      "term": "competing hypotheses",
      "definition": "Two or more proposed explanations or relationships considered as possible answers to the same question.",
      "aliases": [
        "alternative hypotheses",
        "candidate hypotheses"
      ],
      "sceneIds": [
        "scene-explain-and-expect",
        "scene-worked-comparison",
        "scene-practise-and-repair",
        "scene-transfer"
      ]
    },
    {
      "id": "term-discriminating-prediction",
      "term": "discriminating prediction",
      "definition": "An expected observation for which competing hypotheses give different outcomes, allowing evidence to count differently for them.",
      "aliases": [
        "discriminating expected outcome"
      ],
      "sceneIds": [
        "scene-worked-comparison",
        "scene-practise-and-repair",
        "scene-transfer"
      ]
    }
  ]
}
