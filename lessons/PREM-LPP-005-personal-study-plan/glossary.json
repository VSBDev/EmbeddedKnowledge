  "terms": [
    {
      "id": "term-capacity-boundary",
      "term": "capacity boundary",
      "definition": "A learner-declared limit on usable study opportunities after fixed commitments and access constraints are represented, before study tasks are allocated.",
      "aliases": [
        "weekly capacity boundary"
      ],
      "sceneIds": [
        "scene-orientation",
        "scene-concept",
        "scene-worked-example",
        "scene-retrieval-check",
        "scene-misconception",
        "scene-practice",
        "scene-transfer",
        "scene-synthesis",
        "scene-assessment"
      ]
    },
    {
      "id": "term-study-block",
      "term": "study block",
      "definition": "A learner-defined unit of usable study opportunity. Its duration may vary, so blocks are planning units rather than universal measures of effort.",
      "aliases": [
        "focus block"
      ],
      "sceneIds": [
        "scene-concept",
        "scene-worked-example",
        "scene-misconception",
        "scene-practice",
        "scene-transfer",
        "scene-assessment"
      ]
    },
    {
      "id": "term-learning-function",
      "term": "learning function",
      "definition": "The instructional job of a planned activity, such as concept construction, retrieval, problem solving, lab preparation or debrief, or evidence-based revision.",
      "aliases": [
        "study function"
      ],
      "sceneIds": [
        "scene-orientation",
        "scene-concept",
        "scene-worked-example",
        "scene-practice",
        "scene-transfer",
        "scene-synthesis",
        "scene-assessment"
      ]
    },
    {
      "id": "term-delayed-retrieval-contact",
      "term": "delayed retrieval contact",
      "definition": "A later attempt to reconstruct or use earlier learning before answer reveal, separated from the initial learning episode by a planned interval.",
      "aliases": [
        "delayed review contact"
      ],
      "sceneIds": [
        "scene-concept",
        "scene-worked-example",
        "scene-retrieval-check",
        "scene-practice",
        "scene-transfer",
        "scene-synthesis",
        "scene-assessment"
      ]
    },
    {
      "id": "term-recovery-capacity",
      "term": "recovery capacity",
      "definition": "Study-plan capacity deliberately left uncommitted or assigned to a reduced route so disruption can be absorbed without automatically borrowing from later weeks.",
      "aliases": [
        "reserve capacity",
        "recovery reserve"
      ],
      "sceneIds": [
        "scene-orientation",
        "scene-concept",
        "scene-worked-example",
        "scene-misconception",
        "scene-practice",
        "scene-transfer",
        "scene-synthesis",
        "scene-assessment"
      ]
    },
    {
      "id": "term-fixed-commitment",
      "term": "fixed commitment",
      "definition": "A time- or access-bound event that the weekly plan must represent before flexible study is placed, such as an institutionally supervised lab or an unavoidable non-study commitment.",
      "aliases": [],
      "sceneIds": [
        "scene-concept",
        "scene-worked-example",
        "scene-practice",
        "scene-transfer",
        "scene-assessment"
      ]
    },
    {
      "id": "term-contingency",
      "term": "contingency",
      "definition": "A preselected alternative action used when the planned route is unavailable, while preserving the intended learning function when possible.",
      "aliases": [
        "fallback route"
      ],
      "sceneIds": [
        "scene-concept",
        "scene-worked-example",
        "scene-practice",
        "scene-transfer",
        "scene-synthesis",
        "scene-assessment"
      ]
    },
    {
      "id": "term-revision-decision",
      "term": "revision decision",
      "definition": "One of five explicit actions for an incomplete or ineffective planned task: protect, move, split, replace, or remove, justified by outcome and error evidence.",
      "aliases": [],
      "sceneIds": [
        "scene-worked-example",
        "scene-practice",
        "scene-transfer",
        "scene-synthesis",
        "scene-assessment"
      ]
    },
    {
      "id": "term-minimum-viable-study-day",
      "term": "minimum viable study day",
      "definition": "The course's reduced re-entry route during disruption: a small retrieval action, one worked example, and one explicit next action, used without claiming that the full weekly plan was completed.",
      "aliases": [
        "minimum viable route"
      ],
      "sceneIds": [
        "scene-orientation",
        "scene-concept",
        "scene-misconception",
        "scene-transfer",
        "scene-synthesis"
      ]
    }
  ]
}
